rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role in ['admin', 'master']) ||
          (request.auth.token.email == "heliomardejesus87@gmail.com"));
    }

    function isManager() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role in ['manager', 'admin', 'master']) || isAdmin());
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Profiles (User data)
    match /profiles/{userId} {
      allow read: if isOwner(userId) || isManager();
      
      // Admins can create/update anything. 
      // Users can update their own non-sensitive info.
      allow create: if isAdmin();
      allow update: if isAdmin() || (isOwner(userId) && 
                      (!request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['role', 'active', 'uid'])));
      allow delete: if isAdmin();
    }

    // Scales (Escalas de serviço)
    match /scales/{scaleId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    // Notices (Mural de avisos)
    match /notices/{noticeId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    // Swaps (Permutas)
    match /swaps/{swapId} {
      allow read: if isAuthenticated();
      // Allow creation if they are authenticated
      allow create: if isAuthenticated();
      // Only owner or manager can update/delete
      allow update, delete: if isOwner(resource.data.requesterId) || 
                               isOwner(resource.data.respondentId) || 
                               isManager();
    }

    // Notifications
    match /notifications/{notifId} {
      // allow read/write if the notification belongs to the user
      allow read, write: if isAuthenticated() && 
        (request.auth.uid == resource.data.userId || request.auth.uid == request.resource.data.userId);
    }

    // Default deny for anything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
