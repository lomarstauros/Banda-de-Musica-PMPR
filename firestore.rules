rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "heliomardejesus87@gmail.com" ||
         (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role in ['admin', 'master']));
    }

    function isManager() {
      return isAuthenticated() &&
        (isAdmin() || 
         (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role in ['manager', 'admin', 'master']));
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Profiles (User data)
    match /profiles/{userId} {
      // Allow ALL authenticated users to get individual profiles or list them
      allow get, list: if isAuthenticated();
      
      allow create: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      allow update: if isAdmin() || (isOwner(userId) && 
                      (!request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['role', 'active', 'uid'])));
      
      allow delete: if isAdmin();
    }

    // Scales (Escalas de serviço)
    match /scales/{scaleId} {
      allow get, list: if isAuthenticated();
      allow write: if isManager();
    }

    // Notices (Mural de avisos)
    match /notices/{noticeId} {
      allow get, list: if isAuthenticated();
      allow write: if isManager();
    }

    // Swaps (Permutas)
    match /swaps/{swapId} {
      allow get, list: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(resource.data.requester_id) || 
                               isOwner(resource.data.substitute_id) || 
                               isManager();
    }

    // Notifications
    match /notifications/{notifId} {
      // Users can list their own notifications, Managers can list all
      allow list: if isAuthenticated() && (isManager() || query.limit <= 100);
      
      // Individual read access
      allow get: if isAuthenticated() && 
        (request.auth.uid == resource.data.userId || isManager());
      
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isManager());
    }

    // Audit Logs
    match /audit_logs/{logId} {
      allow get, list: if isManager();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // Cities (Lookup data)
    match /cities/{cityId} {
      allow get, list: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
