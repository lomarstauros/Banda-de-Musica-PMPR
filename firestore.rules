rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role in ['admin', 'master']) ||
          (request.auth.token.email == "heliomardejesus87@gmail.com"));
    }

    function isManager() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role in ['manager', 'admin', 'master']) || isAdmin());
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Profiles (User data)
    match /profiles/{userId} {
      allow read: if isOwner(userId) || isManager();
      
      // New users can create their own profile.
      // Admins can create anything.
      allow create: if isOwner(userId) || isAdmin();
      
      // Users can update their own non-sensitive info.
      allow update: if isAdmin() || (isOwner(userId) && 
                      (!request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['role', 'active', 'uid'])));
      allow delete: if isAdmin();
    }

    // Scales (Escalas de serviço)
    match /scales/{scaleId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    // Notices (Mural de avisos)
    match /notices/{noticeId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    // Swaps (Permutas)
    match /swaps/{swapId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      // Only owner or manager can update/delete
      allow update, delete: if isOwner(resource.data.requester_id) || 
                               isOwner(resource.data.substitute_id) || 
                               isManager();
    }

    // Notifications
    match /notifications/{notifId} {
      // allow read if the notification belongs to the user OR user is a manager (to see approvals)
      allow read: if isAuthenticated() && 
        (request.auth.uid == resource.data.userId || isManager());
      
      // allow create/write for authenticated users (to send notifications/updates)
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isManager());
    }

    // Audit Logs
    match /audit_logs/{logId} {
      allow read: if isManager();
      allow create: if isAuthenticated();
      allow update, delete: if false; // Logs are immutable
    }

    // Cities (Lookup data)
    match /cities/{cityId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Default deny for anything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
