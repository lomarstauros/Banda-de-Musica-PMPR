rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.get('email', '').lower() == "heliomardejesus87@gmail.com" ||
        (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.get('role', '').lower() in ['admin', 'master'])
      );
    }

    function isManager() {
      return isAuthenticated() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.get('role', '').lower() == 'manager')
      );
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /profiles/{userId} {
      // Permite leitura individual para qualquer usuário logado
      allow get: if isAuthenticated();
      
      // Restringe a listagem completa (Efetivo) para gestores. 
      // Músicos podem listar apenas com limite (ex: para busca de permutas)
      allow list: if isManager() || (isAuthenticated() && request.query.limit <= 40);
      
      allow create: if isManager();
      allow update: if isManager() || (isOwner(userId) && 
                      !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['role', 'instrument', 'status']));
      allow delete: if isAdmin();
    }

    // Scales (Escalas de serviço)
    match /scales/{scaleId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    // Notices (Mural de avisos)
    match /notices/{noticeId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    // Swaps (Permutas)
    match /swaps/{swapId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(resource.data.requester_id) || 
                               isOwner(resource.data.substitute_id) || 
                               isManager();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isAuthenticated();
      // Permite que qualquer um crie notificações (ex: registros de visualização de escala)
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isOwner(resource.data.userId) || isManager();
    }

    // Audit Logs
    match /audit_logs/{logId} {
      allow read: if isManager();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // Cities (Lookup data)
    match /cities/{cityId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
