rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "heliomardejesus87@gmail.com" ||
        (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
         getUserData().get('role', '') in ['admin', 'master'])
      );
    }

    function isManager() {
      return isAuthenticated() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
         getUserData().get('role', '') in ['manager', 'admin', 'master'])
      );
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Profiles (User data)
    match /profiles/{userId} {
      // Allow ALL authenticated users to get individual profiles or list them
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();
      
      allow create: if isAdmin();
      
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == userId && 
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['fcmTokens', 'updatedAt', 'lastLogin']));
      
      allow delete: if isAdmin();
    }

    // Scales (Escalas de serviço)
    match /scales/{scaleId} {
      allow get, list: if isAuthenticated();
      allow write: if isManager();
    }

    // Notices (Mural de avisos)
    match /notices/{noticeId} {
      allow get, list: if isAuthenticated();
      allow write: if isManager();
    }

    // Swaps (Permutas)
    match /swaps/{swapId} {
      allow get, list: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(resource.data.requester_id) || 
                               isOwner(resource.data.substitute_id) || 
                               isManager();
    }

    // Notifications
    match /notifications/{notifId} {
      // Simplificado: qualquer usuário logado pode ler/listar notificações
      // O filtro de segurança agora é feito via código no app (where userId == uid)
      allow get, list: if isAuthenticated();
      
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isManager());
    }

    // Audit Logs
    match /audit_logs/{logId} {
      // Simplificado: qualquer usuário logado pode ler/listar logs
      allow get, list: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // Cities (Lookup data)
    match /cities/{cityId} {
      allow get, list: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
